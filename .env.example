# ──────────────────────────────────────────────────────────────────────────
# Trading Journal — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored and must never be committed.
# ──────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
# These two are safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Market data (server-side only — never prefixed NEXT_PUBLIC) ──────────────
# Until these are set, the app serves deterministic MOCK prices / FX so it
# runs end-to-end without external accounts.
#
# Stock quotes (also crypto/FX in the future): https://finnhub.io
FINNHUB_API_KEY=

# USD/ILS FX rate. Kept on a SEPARATE provider on purpose so the dual-currency
# portfolio view never depends on the equity feed. e.g. https://exchangerate.host
EXCHANGERATE_API_KEY=
